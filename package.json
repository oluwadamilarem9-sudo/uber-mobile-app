{
  "name": "uber-mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node scripts/start-lan.mjs",
    "start:expo": "expo start --lan",
    "start:tunnel": "node scripts/start-tunnel-v3.mjs",
    "tunnel": "node scripts/start-tunnel-v3.mjs",
    "expo": "node scripts/expo-cli.mjs",
    "check:tunnel": "node scripts/preflight-tunnel.mjs",
    "android": "expo start --lan --android",
    "ios": "expo start --lan --ios",
    "web": "expo start --web",
    "postinstall": "npx patch-package && node ./scripts/ensure-lightningcss-win32.cjs",
    "generate:brand": "node ./scripts/generate-brand-assets.mjs",
    "setup:dev-tools": "npm install --save-dev sharp ngrok@5.0.0-beta.2 @expo/ngrok@^4.1.3",
    "build:android": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios --profile preview",
    "build:ios:simulator": "eas build -p ios --profile preview-simulator",
    "build:all": "eas build -p android --profile preview && eas build -p ios --profile preview",
    "build:android:store": "eas build -p android --profile production",
    "build:ios:store": "eas build -p ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.62.11",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^11.10.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~54.0.0",
    "patch-package": "^8.0.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "lightningcss-win32-x64-msvc": "1.27.0"
  },
  "private": true
}
