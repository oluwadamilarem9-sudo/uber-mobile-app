# Firebase web app config (Console → Project settings → Your apps → Web app)
# Copy this file to `.env` and fill values. Never commit `.env`.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps (enable Maps SDK for Android/iOS + Directions API on the same key or separate keys)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Expo project ID for push tokens (expo.dev → Project → Project settings). Dev client / EAS builds.
EXPO_PUBLIC_EAS_PROJECT_ID=
